NODE_ENV=development
PORT=5000

# Turso (free SQLite edge DB — https://turso.tech)
TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# JWT Secrets — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=6242a9512c3dcef5b4fe7287b671bab933985250607aec06fe0c73f06fa5d3ec38eff1bbe962a40410d377e47a7f658be850760380cd923da0e9255bdd82c93f
JWT_REFRESH_SECRET=35c0235b1b9987a38d993acadb6085d6be0c20662dc2297b1dc0fa4c74978b917a372345b5dfc4303f56d126507298c6c0a175dea87265ecf0838fd3dc2bcf86
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ImageKit (free image upload — https://imagekit.io)
IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id

# CORS — set to your frontend URL
CLIENT_ORIGIN=http://localhost:5173

# Report auto-expiry in hours
REPORT_EXPIRY_HOURS=6
